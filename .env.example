# Optional: OpenReview account login. Anonymous API requests have been
# intermittently challenge-walled by OpenReview since 2026-06-30; setting
# these attaches a bearer token to every OpenReview request instead
# (sources/_openreview_auth.py). Leave unset to keep the previous
# anonymous behavior.
OPENREVIEW_EMAIL=
OPENREVIEW_PASSWORD=
